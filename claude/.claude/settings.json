{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude Code needs your attention' && printf '\\a'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/bin/starship-claude"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-session-driver@superpowers-marketplace": true
  }
}
